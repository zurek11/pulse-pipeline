# Pulse Pipeline — Environment Variables
# Copy this file to .env and fill in values for local development outside Docker.
# When running via `docker compose up`, these are set directly in docker-compose.yml.
#
# Usage: cp .env.example .env

# ── API Service ─────────────────────────────────────────────────────────────
API_ADDR=:8080

# ── Consumer Service ─────────────────────────────────────────────────────────
METRICS_ADDR=:8081

# ── Kafka ────────────────────────────────────────────────────────────────────
# Comma-separated list of broker addresses
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=pulse.events.v1
KAFKA_DLQ_TOPIC=pulse.events.dlq.v1
KAFKA_GROUP_ID=pulse-consumer-group

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=pulse
MONGO_COLLECTION=events

# ── Batch / flush settings (Consumer) ────────────────────────────────────────
CONSUMER_BATCH_SIZE=100
CONSUMER_FLUSH_INTERVAL_MS=1000
CONSUMER_MAX_RETRIES=3
